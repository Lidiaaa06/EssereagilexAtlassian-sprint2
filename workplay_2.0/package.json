{
  "name": "jira-dashboard-gadget-ui-kit",
  "version": "1.1.44-next.4",
  "main": "index.js",
  "license": "MIT",
  "private": true,
  "scripts": {
    "lint": "eslint src/**/* || npm run --silent hook-errors",
    "hook-errors": "echo '\\x1b[31mThe build failed because a Forge UI hook is being used incorrectly. Forge UI hooks follow the same rules as React Hooks but have their own API definitions. See the Forge documentation for details on how to use Forge UI hooks.\n' && exit 1",
    "setup": "npm install && npm --prefix static/gruppi install",
    "build:gruppi": "npm --prefix static/gruppi run build",
    "predeploy": "npm run build:gruppi",
    "deploy": "forge deploy -e development",
    "predeploy:prod": "npm run build:gruppi",
    "deploy:prod": "forge deploy -e production",
    "pretunnel": "npm run build:gruppi",
    "tunnel": "forge tunnel -e development"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0"
  },
  "dependencies": {
    "@forge/api": "^8.0.1",
    "@forge/bridge": "6.0.0",
    "@forge/kvs": "^2.0.1",
    "@forge/react": "12.0.0",
    "@forge/resolver": "2.0.0",
    "react": "^18.2.0"
  }
}
